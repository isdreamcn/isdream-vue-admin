# @see https://cn.vitejs.dev/guide/env-and-mode.html#env-variables-and-modes
# 为了防止意外地将一些环境变量泄漏到客户端，只有以 VITE_ 为前缀的变量才会暴露给经过 vite 处理的代码。

VITE_BASE_URL=/
VITE_PUBLIC_PATH=/
VITE_APP_TITLE=isdream-vue-admin

# 开启 Mock 服务（使用 MSW 模拟后端接口）
VITE_USE_MOCK=true

# ./build 构建相关配置

# 开启 Gzip、Brotli 压缩
VITE_BUILD_GZIP=true
# 生成构建分析报告（stats.html）
VITE_BUILD_ROLLUP_VISUALIZER=true
# 兼容旧版浏览器
VITE_BUILD_LEGACY=true
